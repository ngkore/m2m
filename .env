# Defines the environment (development or production)
NODE_ENV=production

# Port for the Express API server (backend)
PORT=3001

# Port for the Vite dev server (frontend — only used in local development)
PORT_CLIENT=5173

# Bind address for the servers (use 0.0.0.0 to expose on all interfaces)
HOST=0.0.0.0

# Primary Freedium mirror URL for bypassing Medium paywalls.
# Update this if Freedium moves to a new domain.
FREEDIUM_URL=https://freedium-mirror.cfd/
